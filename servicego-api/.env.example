# Variáveis de ambiente — copie para .env e preencha com valores reais
# NUNCA suba o .env real para o repositório

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/servicego"

# JWT — use um segredo longo e aleatório (ex: openssl rand -hex 64)
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio-em-producao"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=production

# CORS — URL do frontend em produção
CORS_ORIGIN="https://seu-dominio.vercel.app"
